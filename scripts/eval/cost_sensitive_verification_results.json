      "direction": "lower_is_better",
      "name": "False-Trigger Rate"
    },
    "EV-MISSED-EXPOSURE-COST": {
      "definition": "For untriggered rows with oracle transfer/prepayment exposure, use the fixture exposure amount left unchecked.",
      "direction": "lower_is_better",
      "name": "Missed Exposure Cost",
      "unit_source": "fixture currency field"
    },
    "EV-TOTAL-DECISION-COST": {
      "definition": "Missed exposure cost plus verification effort cost, with true-negative rows contributing zero.",
      "direction": "lower_is_better",
      "name": "Total Decision Cost",
      "unit_source": "fixture currency field"
    },
    "EV-TRIGGER-RECALL": {
      "definition": "Triggered rows with oracle transfer/prepayment exposure divided by rows with oracle transfer/prepayment exposure.",
      "direction": "higher_is_better",
      "name": "Trigger Recall"
    },
    "EV-VERIFICATION-EFFORT-COST": {
      "definition": "For triggered rows, multiply fixture verification minutes by fixture creator hourly value divided by 60.",
      "direction": "lower_is_better",
      "name": "Verification Effort Cost",
      "unit_source": "fixture currency field"
    }
  },
