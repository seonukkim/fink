{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fink.local/schemas/task.schema.json",
  "type": "object",
  "required": [
    "id",
    "phase",
    "priority",
    "depends_on",
    "scope",
    "allowed_paths",
    "description",
    "acceptance_criteria",
    "machine_gates",
    "paper_sections",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^FINK-[A-Z0-9]+-[0-9]{2}$"
    },
    "phase": {
      "type": "string"
    },
    "priority": {
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "enum": ["S", "M", "L"]
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "machine_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "paper_sections": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_gate": {
      "type": ["string", "array", "null"],
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": ["READY", "DONE", "BLOCKED"]
    },
    "source": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "blocked_reason": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
