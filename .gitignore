
# FInk local-only inputs and run artifacts
.fink/
# Never publish source scans or archives
*.pdf
*.zip
# Environment files — never commit; loaders read them from outside Git only.
.env
*.env
# Runtime/private material
contracts/
uploads/
/models/
models/
indexes/
data/private/
data/raw/
data/unsanitized/
!src/fink/models/
!src/fink/models/**
# Public model registry configs are allowed. These negations come AFTER the
# broad `models/` ignore so that new configs/models/** files stay tracked; a
# trailing `models/` would otherwise re-ignore the configs/models directory.
!configs/
!configs/models/
!configs/models/**
# Python/tooling caches
.venv/
__pycache__/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
*.egg-info/
